---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';

const openings = [
  {
    title: 'Gestionnaire de dossiers sinistres (H/F/X)',
    type: 'CDI · Temps plein · Bruxelles',
    description:
      "Vous gérez les dossiers sinistres de A à Z : ouverture, suivi avec les compagnies, contact client. Expérience en assurance IARD souhaitée, néerlandais un atout."
  },
  {
    title: 'Conseiller commercial en assurances (H/F/X)',
    type: 'CDI · Temps plein · Bruxelles',
    description:
      "Vous accompagnez particuliers et indépendants dans le choix de leurs couvertures. Certification PCP ou volonté de l'obtenir rapidement."
  }
];
---

<BaseLayout title="Jobs" description="Rejoignez BDT Sironval : nos offres d'emploi à Bruxelles dans le courtage en assurances.">
  <div class="relative isolate overflow-hidden bg-ink-950 text-white">
    <div class="absolute -top-32 left-1/3 h-80 w-80 rounded-full bg-mint-500/20 blur-[100px]" aria-hidden="true"></div>
    <div class="container-site relative py-16 sm:py-20">
      <p class="eyebrow text-mint-300">On recrute</p>
      <h1 class="mt-2 font-display text-4xl font-bold tracking-tight sm:text-5xl">Travailler chez BDT Sironval</h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-100/90">
        Un bureau à taille humaine, des clients qu'on connaît par leur prénom, et du café correct. Voici nos postes
        ouverts.
      </p>
    </div>
  </div>

  <section class="container-site py-14" aria-label="Offres d'emploi">
    <div class="grid gap-6 md:grid-cols-2">
      {
        openings.map((job) => (
          <article class="card p-7">
            <p class="eyebrow text-pulse-600">{job.type}</p>
            <h2 class="mt-2 font-display text-xl font-bold text-ink-900">{job.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-ink-600">{job.description}</p>
            <a href="/contact" class="btn-primary mt-5 !py-2.5 text-xs">
              Postuler
            </a>
          </article>
        ))
      }
    </div>
    <div class="card mt-8 flex flex-col items-start gap-4 p-7 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="font-display text-lg font-bold text-ink-900">Pas de poste qui vous correspond ?</h2>
        <p class="mt-1 text-sm text-ink-600">
          Les bons profils nous intéressent toujours. Envoyez une candidature spontanée.
        </p>
      </div>
      <a href="/contact" class="btn-ghost shrink-0 text-xs">Candidature spontanée</a>
    </div>
  </section>

  <ContactCTA title="Envie de nous rejoindre ?" body="Envoyez votre CV et quelques lignes sur vous — on lit tout, on répond à tout le monde." />
</BaseLayout>
