---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCTA from '../../components/ContactCTA.astro';

const numbers = [
  { label: 'Urgences (Europe)', value: '112', note: 'Pompiers et ambulance, 24h/24' },
  { label: 'Police', value: '101', note: 'Urgences policières' },
  { label: 'Card Stop', value: '078 170 170', note: 'Carte bancaire perdue ou volée' },
  { label: 'Doc Stop', value: '00800 2123 2123', note: "Documents d'identité perdus ou volés" },
  { label: 'Centre Antipoisons', value: '070 245 245', note: 'Intoxication, 24h/24' },
  { label: 'Touring dépannage', value: '070 344 777', note: 'Assistance routière' },
  { label: 'BDT Sironval', value: '+32 2 463 19 25', note: 'Votre courtier, heures de bureau' }
];
---

<BaseLayout title="Numéros utiles" description="Les numéros d'urgence et de service à garder sous la main : urgences, Card Stop, dépannage, votre courtier.">
  <div class="relative isolate overflow-hidden bg-ink-950 text-white">
    <div class="absolute -top-32 right-1/4 h-72 w-72 rounded-full bg-coral-500/25 blur-[100px]" aria-hidden="true"></div>
    <div class="container-site relative py-14 sm:py-16">
      <p class="eyebrow text-coral-300">Autres services</p>
      <h1 class="mt-2 font-display text-3xl font-bold tracking-tight sm:text-4xl">Numéros utiles</h1>
      <p class="mt-4 max-w-2xl leading-relaxed text-ink-100/90">
        À enregistrer dans votre téléphone avant d'en avoir besoin.
      </p>
    </div>
  </div>

  <section class="container-site py-12">
    <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        numbers.map((n) => (
          <li class="card flex items-center justify-between gap-4 p-5">
            <div>
              <p class="font-display font-semibold text-ink-900">{n.label}</p>
              <p class="mt-0.5 text-xs text-ink-500">{n.note}</p>
            </div>
            <a
              href={`tel:${n.value.replace(/\s/g, '')}`}
              class="shrink-0 rounded-full bg-pulse-50 px-4 py-2 font-display text-sm font-bold text-pulse-700 hover:bg-pulse-100"
            >
              {n.value}
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <ContactCTA />
</BaseLayout>
