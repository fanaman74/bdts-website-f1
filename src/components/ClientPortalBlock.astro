---
import { portals } from '../data/portals';
import { t } from '../i18n/fr';
---

<section id="portails" class="relative isolate overflow-hidden rounded-3xl bg-ink-950 px-6 py-12 text-white sm:px-12">
  <div
    class="absolute -top-24 -right-24 h-72 w-72 rounded-full bg-pulse-600/40 blur-[90px]"
    aria-hidden="true"
  >
  </div>
  <div class="absolute -bottom-24 -left-16 h-64 w-64 rounded-full bg-coral-500/30 blur-[90px]" aria-hidden="true"></div>

  <div class="relative">
    <p class="eyebrow text-pulse-300">{t.nav.clientZone}</p>
    <h2 class="mt-2 font-display text-2xl font-bold sm:text-3xl">{t.documents.portalPanelTitle}</h2>
    <p class="mt-3 max-w-2xl text-sm leading-relaxed text-ink-200">{t.documents.portalPanelBody}</p>

    <div class="mt-8 grid gap-5 md:grid-cols-2">
      {
        portals.map((portal) => (
          <a
            href={portal.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group rounded-2xl bg-white/5 p-6 ring-1 ring-white/15 backdrop-blur-sm transition hover:bg-white/10 hover:ring-white/30"
          >
            <p class="eyebrow text-coral-300">{portal.label}</p>
            <p class="mt-1.5 font-display text-lg font-bold">{portal.name}</p>
            <p class="mt-2 text-sm leading-relaxed text-ink-200">{portal.description}</p>
            <ul class="mt-4 flex flex-wrap gap-2">
              {portal.features.map((f) => (
                <li class="rounded-full bg-white/10 px-2.5 py-1 text-xs text-ink-100">{f}</li>
              ))}
            </ul>
            <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-pulse-300 group-hover:text-white">
              Se connecter
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
