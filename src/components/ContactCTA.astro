---
interface Props {
  title?: string;
  body?: string;
}

const {
  title = 'Parlons de vos projets',
  body = "Un conseil, un devis, une question sur un contrat existant ? Notre équipe vous répond rapidement — par téléphone, e-mail ou autour d'un café au bureau."
} = Astro.props;
---

<section class="relative isolate overflow-hidden bg-gradient-to-br from-pulse-700 via-pulse-600 to-coral-500">
  <div
    class="absolute inset-0 opacity-20"
    style="background-image: radial-gradient(circle at 20% 50%, white 1px, transparent 1px); background-size: 28px 28px;"
    aria-hidden="true"
  >
  </div>
  <div class="container-site relative flex flex-col items-start gap-8 py-16 sm:py-20 md:flex-row md:items-center md:justify-between">
    <div class="max-w-xl">
      <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">{title}</h2>
      <p class="mt-4 leading-relaxed text-white/85">{body}</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <a href="/contact" class="btn bg-white text-pulse-700 shadow-xl hover:-translate-y-0.5 hover:bg-pulse-50">
        Nous contacter
      </a>
      <a href="/declaration" class="btn-secondary">Déclarer un sinistre</a>
    </div>
  </div>
</section>
