---
interface Props {
  title?: string;
  body?: string;
}

const {
  title = 'Parlons de vos projets',
  body = "Un conseil, un devis, une question sur un contrat existant ? Notre équipe vous répond rapidement — par téléphone, e-mail ou autour d'un café au bureau."
} = Astro.props;
---

<section class="relative isolate overflow-hidden bg-ink-800">
  <div class="dot-grid absolute inset-y-0 right-0 w-1/3 opacity-40" aria-hidden="true"></div>
  <div
    class="absolute -bottom-24 -left-16 h-72 w-72 rounded-full bg-coral-400/15 blur-[90px]"
    aria-hidden="true"
  >
  </div>
  <div class="container-site relative flex flex-col items-start gap-8 py-16 sm:py-20 md:flex-row md:items-center md:justify-between">
    <div class="max-w-xl">
      <p class="eyebrow mb-4 text-coral-400">Contact</p>
      <h2 class="font-display text-3xl font-bold tracking-[-0.03em] text-white sm:text-4xl">{title}</h2>
      <p class="mt-4 leading-relaxed text-ink-100/85">{body}</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <a href="/contact" class="btn-primary">Nous contacter</a>
      <a href="/declaration" class="btn-secondary">Déclarer un sinistre</a>
    </div>
  </div>
</section>
