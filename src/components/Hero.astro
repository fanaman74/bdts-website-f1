---
import { t } from '../i18n/fr';
---

<section class="relative isolate overflow-hidden text-white">
  <div class="hero-mesh" aria-hidden="true">
    <div class="hero-blob hero-blob--violet"></div>
    <div class="hero-blob hero-blob--coral"></div>
    <div class="hero-blob hero-blob--cyan"></div>
    <div class="hero-grid"></div>
  </div>

  <div class="container-site relative grid items-center gap-12 py-20 sm:py-28 lg:grid-cols-[1.15fr_0.85fr] lg:py-32">
    <div>
      <p class="eyebrow mb-5 inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-pulse-200 ring-1 ring-white/15">
        <span class="inline-block h-2 w-2 animate-pulse rounded-full bg-mint-500" aria-hidden="true"></span>
        Courtier indépendant · Bruxelles
      </p>
      <h1 class="font-display text-4xl leading-[1.08] font-bold tracking-tight sm:text-5xl lg:text-6xl">
        Assurance, protection et conseils financiers{' '}
        <span class="bg-gradient-to-r from-pulse-300 via-coral-300 to-coral-400 bg-clip-text text-transparent">
          pour chaque étape de votre vie
        </span>
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-100/90">{t.hero.subheadline}</p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="/devis" class="btn-primary">{t.hero.ctaQuote}</a>
        <a href="/declaration" class="btn-secondary">{t.hero.ctaClaim}</a>
        <a href="/documents" class="btn-secondary">{t.hero.ctaDocuments}</a>
      </div>
      <dl class="mt-12 flex flex-wrap gap-x-10 gap-y-4">
        {
          [
            ['25+', "années d'expérience"],
            ['1 800+', 'clients accompagnés'],
            ['15', "compagnies partenaires"]
          ].map(([num, label]) => (
            <div>
              <dt class="sr-only">{label}</dt>
              <dd class="font-display text-2xl font-bold text-white">{num}</dd>
              <dd class="text-sm text-ink-200">{label}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <!-- Floating glass cards -->
    <div class="relative hidden lg:block" aria-hidden="true">
      <div class="float-slow rounded-2xl bg-white/10 p-5 shadow-2xl ring-1 ring-white/20 backdrop-blur-md">
        <div class="flex items-center gap-3">
          <span class="grid h-10 w-10 place-items-center rounded-xl bg-mint-500/20 text-lg">🛡️</span>
          <div>
            <p class="font-display text-sm font-semibold">Sinistre déclaré</p>
            <p class="text-xs text-ink-200">Pris en charge en 24h</p>
          </div>
          <span class="ml-auto rounded-full bg-mint-500/20 px-2.5 py-1 text-xs font-semibold text-mint-300">Réglé</span>
        </div>
      </div>
      <div class="float-slower mt-5 ml-12 rounded-2xl bg-white/10 p-5 shadow-2xl ring-1 ring-white/20 backdrop-blur-md">
        <p class="font-display text-sm font-semibold">Votre couverture</p>
        <div class="mt-3 space-y-2.5">
          {
            [
              ['Auto omnium', 'w-full', 'bg-pulse-400'],
              ['Habitation', 'w-4/5', 'bg-coral-400'],
              ['Épargne-pension', 'w-3/5', 'bg-mint-500']
            ].map(([label, w, color]) => (
              <div>
                <div class="mb-1 flex justify-between text-xs text-ink-200">
                  <span>{label}</span>
                </div>
                <div class="h-1.5 rounded-full bg-white/10">
                  <div class={`h-1.5 rounded-full ${w} ${color}`} />
                </div>
              </div>
            ))
          }
        </div>
      </div>
      <div class="float-slow mt-5 flex items-center gap-3 rounded-2xl bg-white/10 p-4 shadow-2xl ring-1 ring-white/20 backdrop-blur-md">
        <span class="grid h-9 w-9 place-items-center rounded-full bg-gradient-to-br from-pulse-500 to-coral-500 font-display text-sm font-bold">M</span>
        <p class="text-xs leading-snug text-ink-100">
          « Un conseiller dédié qui connaît votre dossier — pas un call-center. »
        </p>
      </div>
    </div>
  </div>

  <!-- Bottom fade into page -->
  <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-b from-transparent to-white" aria-hidden="true"></div>
</section>
