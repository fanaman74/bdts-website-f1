---
interface Props {
  title: string;
  summary: string;
  date: Date;
  href: string;
  tags?: string[];
  image?: string;
}

const { title, summary, date, href, tags = [], image } = Astro.props;
const formatted = date.toLocaleDateString('fr-BE', { day: 'numeric', month: 'long', year: 'numeric' });
---

<article class="card group relative flex h-full flex-col overflow-hidden">
  {
    image && (
      <div class="relative aspect-[3/2] overflow-hidden bg-ink-900">
        <img
          src={image}
          alt=""
          width="900"
          height="600"
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
        />
      </div>
    )
  }
  <div class="flex flex-1 flex-col p-6">
    <div class="mb-3 flex flex-wrap items-center gap-2">
      <time datetime={date.toISOString()} class="font-mono text-xs text-ink-400">{formatted}</time>
      {
        tags.slice(0, 2).map((tag) => (
          <span class="rounded-full bg-pulse-50 px-2.5 py-0.5 font-mono text-xs text-pulse-700">{tag}</span>
        ))
      }
    </div>
    <h3 class="font-display text-lg font-bold tracking-[-0.02em] text-ink-800 group-hover:text-pulse-800">
      <a href={href} class="after:absolute after:inset-0">{title}</a>
    </h3>
    <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-600">{summary}</p>
    <span class="mt-4 inline-flex items-center gap-1.5 font-mono text-xs tracking-[0.05em] text-coral-700 uppercase">
      Lire l'article
      <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
      </svg>
    </span>
  </div>
</article>
