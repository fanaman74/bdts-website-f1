---
import { t } from '../i18n/fr';

interface Props {
  title: string;
  partner: string;
  category: string;
  documentType: string;
  language: string;
  lastUpdated?: Date;
  description?: string;
  fileUrl: string;
  externalUrl?: string;
  source: 'local' | 'external' | 'portal' | 'manual';
}

const { title, partner, category, documentType, language, lastUpdated, description, fileUrl, externalUrl, source } =
  Astro.props;

const typeLabels: Record<string, string> = {
  'conditions-generales': 'Conditions générales',
  'fiche-info': 'Fiche info',
  commercial: 'Brochure',
  legal: 'Légal',
  'claim-form': 'Formulaire sinistre',
  other: 'Autre'
};

const isPortal = source === 'portal';
const href = isPortal ? externalUrl || fileUrl : externalUrl && source === 'external' ? externalUrl : fileUrl;
---

<article class="card flex flex-col p-5">
  <div class="mb-3 flex flex-wrap gap-2">
    <span class="rounded-full bg-pulse-50 px-2.5 py-0.5 text-xs font-semibold text-pulse-700">
      {typeLabels[documentType] ?? documentType}
    </span>
    <span class="rounded-full bg-ink-50 px-2.5 py-0.5 text-xs font-semibold text-ink-600 uppercase">{language}</span>
    {
      isPortal && (
        <span class="rounded-full bg-coral-50 px-2.5 py-0.5 text-xs font-semibold text-coral-700">
          🔒 {t.documents.portalOnly}
        </span>
      )
    }
  </div>
  <h3 class="font-display text-base font-bold text-ink-900">{title}</h3>
  <p class="mt-1 text-xs font-medium text-ink-500">
    {partner} · {category}
  </p>
  {description && <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-600">{description}</p>}
  <div class="mt-4 flex items-center justify-between gap-3">
    {
      lastUpdated && (
        <time datetime={lastUpdated.toISOString()} class="text-xs text-ink-400">
          {t.documents.lastUpdated} {lastUpdated.toLocaleDateString('fr-BE')}
        </time>
      )
    }
    <a
      href={href}
      class:list={['btn !px-4 !py-2 text-xs', isPortal ? 'bg-ink-100 text-ink-800' : 'bg-pulse-600 text-white hover:bg-pulse-700']}
      target={source !== 'local' ? '_blank' : undefined}
      rel={source !== 'local' ? 'noopener noreferrer' : undefined}
    >
      {isPortal ? t.documents.goToPortal : source === 'external' ? t.documents.open : t.documents.download}
    </a>
  </div>
</article>
