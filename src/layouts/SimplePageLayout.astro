---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
}

const { title, description, eyebrow = 'Informations' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="relative isolate overflow-hidden bg-ink-950 text-white">
    <div class="absolute -top-32 right-1/3 h-72 w-72 rounded-full bg-pulse-600/25 blur-[100px]" aria-hidden="true"></div>
    <div class="container-site relative py-14 sm:py-16">
      <p class="eyebrow text-pulse-300">{eyebrow}</p>
      <h1 class="mt-2 font-display text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
    </div>
  </div>
  <div class="container-site max-w-3xl py-12">
    <div class="prose-service">
      <slot />
    </div>
  </div>
</BaseLayout>
